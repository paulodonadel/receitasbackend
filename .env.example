# Configurações do banco de dados
MONGODB_URI=mongodb+srv://seu_usuario:sua_senha@cluster.mongodb.net/receitas_db?retryWrites=true&w=majority

# Configurações JWT
JWT_SECRET=sua_chave_secreta_jwt_muito_segura_aqui
JWT_EXPIRE=24h

# Configurações de e-mail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=paulodonadel@gmail.com
EMAIL_PASS=sua_senha_de_app_gmail
EMAIL_FROM="Dr. Paulo Donadel <paulodonadel@gmail.com>"

# Configurações do servidor
PORT=5000
NODE_ENV=production

# Chave de criptografia AES-256 para senhas no LoginLog
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=sua_chave_hex_de_64_caracteres_aqui

# Configurações do React (apenas para referência)
REACT_APP_API_URL=https://seu-backend.onrender.com

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_TOKEN=seu_token_permanente_da_meta
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_VERIFY_TOKEN=escolha_uma_string_secreta

